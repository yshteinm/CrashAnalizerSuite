<Window x:Class="CrashAnalyzer.WpfApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Crash Analyzer" Height="600" Width="900">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Button Name="OpenCrashDumpButton"
                Grid.Column="0"
                Width="150"
                Height="30"
                HorizontalAlignment="Left"
                Content="Open Crash Dump"
                Click="OpenCrashDumpButton_Click" />

            <Button Name="OpenPdbButton"
                Grid.Column="2"
                Width="120"
                Height="30"
                HorizontalAlignment="Left"
                Content="Open PDB"
                Click="OpenPdbButton_Click" />

            <TextBox Name="PromptTextBox"
                 Grid.Column="4"
                 Height="30"
                 VerticalContentAlignment="Center"
                 ToolTip="Ask a question about the loaded dump"
                 KeyDown="PromptTextBox_KeyDown" />

            <Button Name="AskButton"
                Grid.Column="5"
                Margin="8,0,0,0"
                Width="90"
                Height="30"
                Content="Ask"
                Click="AskButton_Click" />
        </Grid>

        <ScrollViewer Grid.Row="1"
                      Margin="0,12,0,0"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <TextBlock Name="DmpStatusTextBlock"
                       Grid.Row="0"
                       Text="No DMP selected."
                       TextWrapping="Wrap" />

                <TextBlock Name="PdbStatusTextBlock"
                       Grid.Row="1"
                       Margin="0,4,0,0"
                       Text="No PDB selected."
                       TextWrapping="Wrap" />

                <ScrollViewer Grid.Row="2"
                              Margin="0,8,0,0"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <DockPanel LastChildFill="True">
                        <ProgressBar Name="ThinkingProgressBar"
                                     DockPanel.Dock="Right"
                                     Width="120"
                                     Height="8"
                                     Margin="10,4,0,0"
                                     IsIndeterminate="True"
                                     Visibility="Collapsed"
                                     VerticalAlignment="Top" />

                        <TextBlock Name="PromptAnswerTextBlock"
                                   Text="Prompt answer will appear here after loading a dump."
                                   TextWrapping="Wrap" />
                    </DockPanel>
                </ScrollViewer>
            </Grid>
        </ScrollViewer>

        <GridSplitter Grid.Row="2"
                      Height="6"
                      HorizontalAlignment="Stretch"
                      VerticalAlignment="Center"
                      Background="#33000000"
                      ResizeDirection="Rows"
                      ResizeBehavior="PreviousAndNext"
                      ShowsPreview="True" />

        <TextBox Name="OutputTextBox"
                 Grid.Row="3"
                 Margin="0,12,0,0"
                 AcceptsReturn="True"
                 TextWrapping="Wrap"
                 VerticalScrollBarVisibility="Auto"
                 HorizontalScrollBarVisibility="Auto"
                 IsReadOnly="True" />
    </Grid>
</Window>
